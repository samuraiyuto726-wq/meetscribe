# ============================================================
# Copy-trading bot configuration
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real credentials.
# ============================================================

# ---- Execution mode ----------------------------------------
# true  → use internal mock data (no network, no account needed)
USE_MOCK=true

# true  → log orders but never call the exchange
DRY_RUN=true

# ---- Strategy ----------------------------------------------
# Fixed USD amount to risk per mirrored trade
COPY_AMOUNT_USD=1.0

# Optional: skip leaderboard and always mirror this specific trader
# TARGET_USERNAME=alpha_trader

# ---- API endpoints (only needed when USE_MOCK=false) -------
# LEADERBOARD_URL=https://api.bybit.com/v5/copytrading/public/master-order
# TRADE_FEED_URL=wss://stream.bybit.com/v5/public/linear

# ---- Authentication (only needed when USE_MOCK=false) ------
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here

# ---- Safeguards --------------------------------------------
MAX_SIGNALS_PER_MINUTE=5
MAX_SIGNALS_PER_HOUR=20
DUPLICATE_WINDOW_SECONDS=120

# ---- Logging -----------------------------------------------
LOG_FILE=trading_bot.log
LOG_LEVEL=INFO
