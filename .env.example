# ============================================================
# Polymarket copy-trading bot configuration
# Copy to .env and fill in your values.
# .env is gitignored – NEVER commit real credentials.
# ============================================================

# ---- Execution mode ----------------------------------------
# true  → log simulated orders, never touch any account (safe default)
DRY_RUN=true

# ---- Strategy ----------------------------------------------
# Fixed USDC amount to spend per mirrored trade
COPY_AMOUNT_USD=1.0

# Leaderboard time window for ranking: 1d | 1w | 1m | all
LEADERBOARD_WINDOW=1m

# Optional: skip leaderboard and always mirror this wallet address
# TARGET_WALLET=0xYourTargetWalletAddress

# ---- Wallet (required for DRY_RUN=false) -------------------
# Your Polygon wallet private key – keep this secret
# PRIVATE_KEY=0xYourPrivateKeyHere

# Polygon chain ID: 137 = mainnet  |  80002 = Amoy testnet
CHAIN_ID=137

# ---- Polymarket API endpoints (defaults are correct) -------
LEADERBOARD_URL=https://data-api.polymarket.com/leaderboard
ACTIVITY_URL=https://data-api.polymarket.com/activity
CLOB_HOST=https://clob.polymarket.com

# ---- Polling -----------------------------------------------
# How often to check the target's activity (seconds)
POLL_INTERVAL_SECONDS=15
ACTIVITY_LIMIT=20

# ---- Safeguards --------------------------------------------
# Max trades to copy per hour / per day
MAX_SIGNALS_PER_HOUR=10
MAX_SIGNALS_PER_DAY=30

# Ignore trades with price outside this band (0.0–1.0 probability)
# Avoids near-certain (expensive) and near-zero (very risky) outcomes
MIN_PRICE=0.05
MAX_PRICE=0.95

# How long to remember a trade ID to prevent duplicates (seconds)
DUPLICATE_WINDOW_SECONDS=3600

# ---- Logging -----------------------------------------------
LOG_FILE=trading_bot.log
LOG_LEVEL=INFO
